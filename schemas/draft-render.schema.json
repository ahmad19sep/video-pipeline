{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cutmachine.local/schemas/draft-render-v1.schema.json",
  "title": "CutMachine Draft Render Record v1",
  "type": "object", "additionalProperties": false,
  "required": ["version", "projectId", "createdAt", "inputPath", "outputPath", "composition", "fps", "width", "height", "expectedDuration", "actualDuration", "videoCodec", "audioCodec"],
  "properties": {
    "version": {"const": 1}, "projectId": {"type": "string", "pattern": "^[A-Za-z0-9_-]+$"}, "createdAt": {"type": "string", "format": "date-time"},
    "inputPath": {"$ref": "#/$defs/safeRelativePath"}, "outputPath": {"$ref": "#/$defs/safeRelativePath"}, "composition": {"const": "CutMachineDraft"},
    "fps": {"type": "number", "minimum": 1}, "width": {"type": "integer", "minimum": 1}, "height": {"type": "integer", "minimum": 1},
    "expectedDuration": {"type": "number", "exclusiveMinimum": 0}, "actualDuration": {"type": "number", "exclusiveMinimum": 0},
    "videoCodec": {"type": "string", "minLength": 1}, "audioCodec": {"type": "string", "minLength": 1}
  },
  "$defs": {"safeRelativePath": {"type": "string", "minLength": 1, "allOf": [{"not": {"pattern": "(^[A-Za-z]:)|(^/)|(^\\\\)|(^~)"}}, {"not": {"pattern": "(^|[\\\\/])\\.\\.([\\\\/]|$)"}}]}}
}
