{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cutmachine.local/schemas/normalized-transcript-v1.schema.json",
  "title": "CutMachine Roman Urdu Transcript v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "projectId", "language", "displayLanguage", "durationSeconds", "segments", "words", "provenance"],
  "properties": {
    "version": {"const": 1},
    "projectId": {"type": "string", "pattern": "^[A-Za-z0-9_-]+$"},
    "language": {"type": "string", "minLength": 2},
    "displayLanguage": {"const": "roman-urdu"},
    "durationSeconds": {"type": "number", "minimum": 0},
    "segments": {"type": "array", "items": {"$ref": "#/$defs/segment"}},
    "words": {"type": "array", "items": {"$ref": "#/$defs/word"}},
    "provenance": {"$ref": "#/$defs/provenance"}
  },
  "$defs": {
    "segment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "start", "end", "text", "wordIds"],
      "properties": {
        "id": {"type": "string", "pattern": "^segment_[0-9]{6}$"},
        "start": {"type": "number", "minimum": 0},
        "end": {"type": "number", "minimum": 0},
        "text": {"type": "string"},
        "wordIds": {"type": "array", "items": {"type": "string", "pattern": "^word_[0-9]{6}$"}}
      }
    },
    "word": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "segmentId", "start", "end", "raw", "display", "language", "confidence", "source", "normalizationSource", "lockedTiming"],
      "properties": {
        "id": {"type": "string", "pattern": "^word_[0-9]{6}$"},
        "segmentId": {"type": "string", "pattern": "^segment_[0-9]{6}$"},
        "start": {"type": "number", "minimum": 0},
        "end": {"type": "number", "minimum": 0},
        "raw": {"type": "string", "minLength": 1},
        "display": {"type": "string", "minLength": 1},
        "language": {"type": "string", "minLength": 2},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "source": {"const": "faster-whisper"},
        "normalizationSource": {"enum": ["preserved", "technical-glossary", "local-lexicon", "deterministic-transliteration", "external-refinement"]},
        "lockedTiming": {"const": true}
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["createdAt", "rawTranscriptPath", "glossaryPath", "lexiconPath", "refinement", "wordCountPreserved", "timingPreserved"],
      "properties": {
        "createdAt": {"type": "string", "format": "date-time"},
        "rawTranscriptPath": {"$ref": "#/$defs/safeRelativePath"},
        "glossaryPath": {"$ref": "#/$defs/safeRelativePath"},
        "lexiconPath": {"$ref": "#/$defs/safeRelativePath"},
        "refinement": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "attemptedBatches", "appliedBatches", "failedBatches", "provider"],
          "properties": {
            "enabled": {"type": "boolean"},
            "attemptedBatches": {"type": "integer", "minimum": 0},
            "appliedBatches": {"type": "integer", "minimum": 0},
            "failedBatches": {"type": "integer", "minimum": 0},
            "provider": {"type": ["string", "null"]}
          }
        },
        "wordCountPreserved": {"const": true},
        "timingPreserved": {"const": true}
      }
    },
    "safeRelativePath": {
      "type": "string",
      "minLength": 1,
      "allOf": [
        {"not": {"pattern": "(^[A-Za-z]:)|(^/)|(^\\\\)|(^~)"}},
        {"not": {"pattern": "(^|[\\\\/])\\.\\.([\\\\/]|$)"}}
      ]
    }
  }
}
