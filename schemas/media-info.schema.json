{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cutmachine.local/schemas/media-info-v1.schema.json",
  "title": "CutMachine Media Info v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "projectId", "generatedAt", "source", "format", "video", "audio", "artifacts"],
  "properties": {
    "version": {"const": 1},
    "projectId": {"type": "string", "pattern": "^[A-Za-z0-9_-]+$"},
    "generatedAt": {"type": "string", "format": "date-time"},
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "sizeBytes"],
      "properties": {
        "path": {"$ref": "#/$defs/safeRelativePath"},
        "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "sizeBytes": {"type": "integer", "minimum": 1}
      }
    },
    "format": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "durationSeconds", "bitRate"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "durationSeconds": {"type": "number", "exclusiveMinimum": 0},
        "bitRate": {"type": ["integer", "null"], "minimum": 0}
      }
    },
    "video": {
      "type": "object",
      "additionalProperties": false,
      "required": ["codec", "width", "height", "pixelFormat", "frameRate", "rotation", "durationSeconds"],
      "properties": {
        "codec": {"type": "string", "minLength": 1},
        "width": {"type": "integer", "minimum": 1},
        "height": {"type": "integer", "minimum": 1},
        "pixelFormat": {"type": ["string", "null"]},
        "frameRate": {"type": "number", "exclusiveMinimum": 0},
        "rotation": {"type": "integer", "minimum": -360, "maximum": 360},
        "durationSeconds": {"type": "number", "exclusiveMinimum": 0}
      }
    },
    "audio": {
      "type": "object",
      "additionalProperties": false,
      "required": ["codec", "sampleRate", "channels", "channelLayout", "durationSeconds"],
      "properties": {
        "codec": {"type": "string", "minLength": 1},
        "sampleRate": {"type": "integer", "minimum": 1},
        "channels": {"type": "integer", "minimum": 1},
        "channelLayout": {"type": ["string", "null"]},
        "durationSeconds": {"type": "number", "exclusiveMinimum": 0}
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["proxy", "originalAudio", "transcriptionAudio", "contactSheet", "frames"],
      "properties": {
        "proxy": {"$ref": "#/$defs/safeRelativePath"},
        "originalAudio": {"$ref": "#/$defs/safeRelativePath"},
        "transcriptionAudio": {"$ref": "#/$defs/safeRelativePath"},
        "contactSheet": {"$ref": "#/$defs/safeRelativePath"},
        "frames": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/safeRelativePath"}}
      }
    }
  },
  "$defs": {
    "safeRelativePath": {
      "type": "string",
      "minLength": 1,
      "allOf": [
        {"not": {"pattern": "(^[A-Za-z]:)|(^/)|(^\\\\)|(^~)"}},
        {"not": {"pattern": "(^|[\\\\/])\\.\\.([\\\\/]|$)"}}
      ]
    }
  }
}

