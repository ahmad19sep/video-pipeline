{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cutmachine.local/schemas/delivery-record-v1.schema.json",
  "title": "CutMachine Final Delivery Record v1",
  "type": "object", "additionalProperties": false,
  "required": ["version", "projectId", "createdAt", "inputPath", "workspaceOutputPath", "deliveryPath", "sha256", "fps", "width", "height", "duration", "videoCodec", "audioCodec", "approvedDecisionSha256"],
  "properties": {
    "version": {"const": 1}, "projectId": {"type": "string", "pattern": "^[A-Za-z0-9_-]+$"}, "createdAt": {"type": "string", "format": "date-time"},
    "inputPath": {"$ref": "#/$defs/safeRelativePath"}, "workspaceOutputPath": {"$ref": "#/$defs/safeRelativePath"}, "deliveryPath": {"$ref": "#/$defs/safeRelativePath"}, "sha256": {"$ref": "#/$defs/sha256"},
    "fps": {"type": "number", "exclusiveMinimum": 0}, "width": {"type": "integer", "minimum": 1}, "height": {"type": "integer", "minimum": 1}, "duration": {"type": "number", "exclusiveMinimum": 0}, "videoCodec": {"type": "string", "minLength": 1}, "audioCodec": {"type": "string", "minLength": 1}, "approvedDecisionSha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {"safeRelativePath": {"type": "string", "minLength": 1, "allOf": [{"not": {"pattern": "(^[A-Za-z]:)|(^/)|(^\\\\)|(^~)"}}, {"not": {"pattern": "(^|[\\\\/])\\.\\.([\\\\/]|$)"}}]}, "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}
}
