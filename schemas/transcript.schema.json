{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cutmachine.local/schemas/transcript-v1.schema.json",
  "title": "CutMachine Raw Transcript v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "projectId", "language", "durationSeconds", "segments", "words", "provenance"],
  "properties": {
    "version": {"const": 1},
    "projectId": {"type": "string", "pattern": "^[A-Za-z0-9_-]+$"},
    "language": {"type": "string", "minLength": 2},
    "durationSeconds": {"type": "number", "minimum": 0},
    "segments": {"type": "array", "items": {"$ref": "#/$defs/segment"}},
    "words": {"type": "array", "items": {"$ref": "#/$defs/word"}},
    "provenance": {"$ref": "#/$defs/provenance"}
  },
  "$defs": {
    "segment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "start", "end", "text", "wordIds"],
      "properties": {
        "id": {"type": "string", "pattern": "^segment_[0-9]{6}$"},
        "start": {"type": "number", "minimum": 0},
        "end": {"type": "number", "minimum": 0},
        "text": {"type": "string"},
        "wordIds": {"type": "array", "items": {"type": "string", "pattern": "^word_[0-9]{6}$"}}
      }
    },
    "word": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "segmentId", "start", "end", "raw", "display", "language", "confidence", "source", "normalizationSource", "lockedTiming"],
      "properties": {
        "id": {"type": "string", "pattern": "^word_[0-9]{6}$"},
        "segmentId": {"type": "string", "pattern": "^segment_[0-9]{6}$"},
        "start": {"type": "number", "minimum": 0},
        "end": {"type": "number", "minimum": 0},
        "raw": {"type": "string", "minLength": 1},
        "display": {"type": "string", "minLength": 1},
        "language": {"type": "string", "minLength": 2},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "source": {"enum": ["faster-whisper", "manual-script"]},
        "normalizationSource": {"enum": ["raw-transcript", "manual-script"]},
        "lockedTiming": {"const": true}
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["createdAt", "audioPath", "requested", "effective", "fallbackReason", "wordTimestamps", "vadEnabled"],
      "properties": {
        "createdAt": {"type": "string", "format": "date-time"},
        "audioPath": {"$ref": "#/$defs/safeRelativePath"},
        "requested": {"$ref": "#/$defs/modelSettings"},
        "effective": {"$ref": "#/$defs/modelSettings"},
        "fallbackReason": {"type": ["string", "null"]},
        "wordTimestamps": {"const": true},
        "vadEnabled": {"type": "boolean"},
        "manualScriptPath": {"$ref": "#/$defs/safeRelativePath"},
        "manualScriptSha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "alignmentMethod": {"enum": ["weighted-script-duration", "timestamped-script-cues"]}
      }
    },
    "modelSettings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model", "device", "computeType"],
      "properties": {
        "model": {"type": "string", "minLength": 1},
        "device": {"enum": ["cpu", "cuda"]},
        "computeType": {"type": "string", "minLength": 1}
      }
    },
    "safeRelativePath": {
      "type": "string",
      "minLength": 1,
      "allOf": [
        {"not": {"pattern": "(^[A-Za-z]:)|(^/)|(^\\\\)|(^~)"}},
        {"not": {"pattern": "(^|[\\\\/])\\.\\.([\\\\/]|$)"}}
      ]
    }
  }
}
