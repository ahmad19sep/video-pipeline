{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cutmachine.local/schemas/reframe-analysis-v1.schema.json",
  "title": "CutMachine Reframe Analysis v1",
  "type": "object", "additionalProperties": false,
  "required": ["version", "projectId", "createdAt", "detector", "mode", "targetAspect", "maxDigitalZoom", "headroom", "samples", "crop", "fallbackReason"],
  "properties": {
    "version": {"const": 1}, "projectId": {"type": "string", "pattern": "^[A-Za-z0-9_-]+$"}, "createdAt": {"type": "string", "format": "date-time"}, "detector": {"enum": ["injected-local", "unavailable", "disabled-neutral"]}, "mode": {"enum": ["face-aware", "center-fallback", "neutral"]}, "targetAspect": {"type": "number", "minimum": 0.25, "maximum": 4}, "maxDigitalZoom": {"type": "number", "minimum": 1, "maximum": 1.5}, "headroom": {"type": "number", "minimum": 0, "maximum": 0.3},
    "samples": {"type": "array", "maxItems": 300, "items": {"type": "object", "additionalProperties": false, "required": ["time", "centerX", "centerY", "confidence"], "properties": {"time": {"type": "number", "minimum": 0}, "centerX": {"type": "number", "minimum": 0, "maximum": 1}, "centerY": {"type": "number", "minimum": 0, "maximum": 1}, "confidence": {"type": "number", "minimum": 0, "maximum": 1}}}},
    "crop": {"type": "object", "additionalProperties": false, "required": ["sourceWidth", "sourceHeight", "x", "y", "width", "height", "centerX", "centerY"], "properties": {"sourceWidth": {"type": "integer", "minimum": 1}, "sourceHeight": {"type": "integer", "minimum": 1}, "x": {"type": "integer", "minimum": 0}, "y": {"type": "integer", "minimum": 0}, "width": {"type": "integer", "minimum": 2}, "height": {"type": "integer", "minimum": 2}, "centerX": {"type": "number", "minimum": 0, "maximum": 1}, "centerY": {"type": "number", "minimum": 0, "maximum": 1}}},
    "fallbackReason": {"type": ["string", "null"], "maxLength": 300}
  }
}
