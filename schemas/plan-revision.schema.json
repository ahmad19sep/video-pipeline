{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cutmachine.local/schemas/plan-revision-v1.schema.json",
  "title": "CutMachine Edit Plan Revision v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "projectId", "operations"],
  "properties": {
    "version": {"const": 1},
    "projectId": {"type": "string", "pattern": "^[A-Za-z0-9_-]+$"},
    "operations": {"type": "array", "minItems": 1, "maxItems": 50, "items": {"$ref": "#/$defs/operation"}}
  },
  "$defs": {
    "camera": {
      "type": "object", "additionalProperties": false, "required": ["mode", "scaleStart", "scaleEnd", "focus"],
      "properties": {
        "mode": {"enum": ["static", "punch-in", "slow-zoom", "reframe-left", "reframe-right", "return-wide", "face-follow"]},
        "scaleStart": {"type": "number", "minimum": 0.75, "maximum": 1.5}, "scaleEnd": {"type": "number", "minimum": 0.75, "maximum": 1.5},
        "focus": {"enum": ["center", "face", "left", "right", "custom"]}
      }
    },
    "operation": {
      "oneOf": [
        {"type": "object", "additionalProperties": false, "required": ["op", "wordId", "emphasis"], "properties": {"op": {"const": "set-caption-emphasis"}, "wordId": {"type": "string", "pattern": "^word_[0-9]{6}$"}, "emphasis": {"type": "boolean"}}},
        {"type": "object", "additionalProperties": false, "required": ["op", "sceneId", "camera"], "properties": {"op": {"const": "set-scene-camera"}, "sceneId": {"type": "string", "pattern": "^scene_[0-9]{6}$"}, "camera": {"$ref": "#/$defs/camera"}}},
        {"type": "object", "additionalProperties": false, "required": ["op", "sceneId", "layout"], "properties": {"op": {"const": "set-scene-layout"}, "sceneId": {"type": "string", "pattern": "^scene_[0-9]{6}$"}, "layout": {"enum": ["speaker-fullscreen", "speaker-with-title", "speaker-with-broll", "fullscreen-broll", "split-screen", "browser-demo", "mobile-demo", "graphic-fullscreen", "picture-in-picture"]}}},
        {"type": "object", "additionalProperties": false, "required": ["op", "sceneId", "query"], "properties": {"op": {"const": "set-scene-broll-query"}, "sceneId": {"type": "string", "pattern": "^scene_[0-9]{6}$"}, "query": {"type": ["string", "null"], "minLength": 1, "maxLength": 120}}},
        {"type": "object", "additionalProperties": false, "required": ["op", "captionPreset"], "properties": {"op": {"const": "set-caption-preset"}, "captionPreset": {"enum": ["roman-word-highlight", "clean-two-line", "hook", "definition", "question", "viral-punch", "boxed-keyword", "urdu-script"]}}}
      ]
    }
  }
}
