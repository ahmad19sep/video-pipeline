{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cutmachine.local/schemas/asset-pins-v1.schema.json",
  "title": "CutMachine Explicit Owned B-roll Pins v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "projectId", "pins"],
  "properties": {
    "version": {"const": 1},
    "projectId": {"type": "string", "pattern": "^[A-Za-z0-9_-]+$"},
    "pins": {
      "type": "array",
      "maxItems": 50,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sceneId", "localAssetId"],
        "properties": {
          "sceneId": {"type": "string", "pattern": "^scene_[0-9]{6}$"},
          "localAssetId": {"type": "string", "pattern": "^local_[a-f0-9]{16}$"}
        }
      }
    }
  }
}
