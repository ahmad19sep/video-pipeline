{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cutmachine.local/schemas/remapped-transcript-v1.schema.json",
  "title": "CutMachine Remapped Transcript v1",
  "type": "object", "additionalProperties": false,
  "required": ["version", "projectId", "language", "displayLanguage", "sourceDuration", "durationSeconds", "segments", "words", "provenance"],
  "properties": {
    "version": {"const": 1}, "projectId": {"type": "string", "pattern": "^[A-Za-z0-9_-]+$"}, "language": {"type": "string", "minLength": 2},
    "displayLanguage": {"const": "roman-urdu"}, "sourceDuration": {"type": "number", "exclusiveMinimum": 0}, "durationSeconds": {"type": "number", "exclusiveMinimum": 0},
    "segments": {"type": "array", "items": {"$ref": "#/$defs/segment"}}, "words": {"type": "array", "items": {"$ref": "#/$defs/word"}},
    "provenance": {"type": "object", "additionalProperties": false, "required": ["sourceTranscriptPath", "timelinePath", "timeMapPath", "identifiersPreserved"], "properties": {
      "sourceTranscriptPath": {"$ref": "#/$defs/safeRelativePath"}, "timelinePath": {"$ref": "#/$defs/safeRelativePath"}, "timeMapPath": {"$ref": "#/$defs/safeRelativePath"}, "identifiersPreserved": {"const": true}
    }}
  },
  "$defs": {
    "segment": {"type": "object", "additionalProperties": false, "required": ["id", "sourceStart", "sourceEnd", "start", "end", "text", "wordIds"], "properties": {
      "id": {"type": "string", "pattern": "^segment_[0-9]{6}$"}, "sourceStart": {"type": "number", "minimum": 0}, "sourceEnd": {"type": "number", "minimum": 0}, "start": {"type": "number", "minimum": 0}, "end": {"type": "number", "minimum": 0}, "text": {"type": "string"}, "wordIds": {"type": "array", "items": {"type": "string", "pattern": "^word_[0-9]{6}$"}}
    }},
    "word": {"type": "object", "additionalProperties": false, "required": ["id", "segmentId", "sourceStart", "sourceEnd", "start", "end", "raw", "display", "language", "confidence", "source", "normalizationSource", "lockedTiming"], "properties": {
      "id": {"type": "string", "pattern": "^word_[0-9]{6}$"}, "segmentId": {"type": "string", "pattern": "^segment_[0-9]{6}$"}, "sourceStart": {"type": "number", "minimum": 0}, "sourceEnd": {"type": "number", "minimum": 0}, "start": {"type": "number", "minimum": 0}, "end": {"type": "number", "minimum": 0}, "raw": {"type": "string", "minLength": 1}, "display": {"type": "string", "minLength": 1}, "language": {"type": "string", "minLength": 2}, "confidence": {"type": "number", "minimum": 0, "maximum": 1}, "source": {"enum": ["faster-whisper", "manual-script"]}, "normalizationSource": {"enum": ["preserved", "manual-script", "technical-glossary", "approved-correction", "local-lexicon", "deterministic-transliteration", "external-refinement"]}, "lockedTiming": {"const": true}
    }},
    "safeRelativePath": {"type": "string", "minLength": 1, "allOf": [{"not": {"pattern": "(^[A-Za-z]:)|(^/)|(^\\\\)|(^~)"}}, {"not": {"pattern": "(^|[\\\\/])\\.\\.([\\\\/]|$)"}}]}
  }
}
