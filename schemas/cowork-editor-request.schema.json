{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cutmachine.local/schemas/cowork-editor-request-v1.schema.json",
  "title": "CutMachine Cowork Editor Request v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "projectId", "createdAt", "instruction", "inputPaths", "outputPath", "constraints"],
  "properties": {
    "version": {"const": 1},
    "projectId": {"type": "string", "pattern": "^[A-Za-z0-9_-]+$"},
    "createdAt": {"type": "string", "format": "date-time"},
    "instruction": {"type": "string", "minLength": 1, "maxLength": 1000},
    "inputPaths": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/safeRelativePath"}
    },
    "outputPath": {"$ref": "#/$defs/safeRelativePath"},
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["jsonOnly", "typedRevisionOnly", "preserveTranscript", "allowExecutableContent"],
      "properties": {
        "jsonOnly": {"const": true},
        "typedRevisionOnly": {"const": true},
        "preserveTranscript": {"const": true},
        "allowExecutableContent": {"const": false}
      }
    }
  },
  "$defs": {
    "safeRelativePath": {
      "type": "string",
      "minLength": 1,
      "allOf": [
        {"not": {"pattern": "(^[A-Za-z]:)|(^/)|(^\\\\)|(^~)"}},
        {"not": {"pattern": "(^|[\\\\/])\\.\\.([\\\\/]|$)"}}
      ]
    }
  }
}
