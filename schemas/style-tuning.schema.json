{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cutmachine.local/schemas/style-tuning-v1.schema.json",
  "title": "CutMachine Bounded Style Tuning v1",
  "type": "object", "additionalProperties": false,
  "required": ["version", "updatedAt", "sourceEventDigest", "eventCount", "profiles"],
  "properties": {
    "version": {"const": 1}, "updatedAt": {"type": "string", "format": "date-time"}, "sourceEventDigest": {"$ref": "#/$defs/sha256"}, "eventCount": {"type": "integer", "minimum": 0},
    "profiles": {"type": "array", "maxItems": 4, "uniqueItems": true, "items": {"type": "object", "additionalProperties": false, "required": ["mode", "active", "captionPreset", "transitionDensity", "visualChangeTargetSeconds", "effectBudgetScale", "preferredSignals", "rejectedSignals"], "properties": {
      "mode": {"enum": ["fast", "balanced", "energetic", "cinematic"]}, "active": {"type": "boolean"}, "captionPreset": {"type": ["string", "null"], "enum": ["roman-word-highlight", "clean-two-line", "hook", "definition", "question", "viral-punch", "boxed-keyword", "urdu-script", null]}, "transitionDensity": {"type": ["string", "null"], "enum": ["none", "low", "medium", null]}, "visualChangeTargetSeconds": {"type": ["number", "null"], "minimum": 1.5, "maximum": 12}, "effectBudgetScale": {"type": ["number", "null"], "minimum": 0.5, "maximum": 1}, "preferredSignals": {"type": "integer", "minimum": 0}, "rejectedSignals": {"type": "integer", "minimum": 0}
    }}}
  },
  "$defs": {"sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}
}
