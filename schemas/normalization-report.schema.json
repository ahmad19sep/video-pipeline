{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cutmachine.local/schemas/normalization-report-v1.schema.json",
  "title": "CutMachine Transcript Normalization Report v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "projectId", "generatedAt", "lowConfidenceThreshold", "counts", "lowConfidenceWords", "warnings"],
  "properties": {
    "version": {"const": 1},
    "projectId": {"type": "string", "pattern": "^[A-Za-z0-9_-]+$"},
    "generatedAt": {"type": "string", "format": "date-time"},
    "lowConfidenceThreshold": {"type": "number", "minimum": 0, "maximum": 1},
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["words", "preserved", "technicalGlossary", "approvedCorrections", "localLexicon", "transliterated", "externallyRefined"],
      "properties": {
        "words": {"type": "integer", "minimum": 0},
        "preserved": {"type": "integer", "minimum": 0},
        "technicalGlossary": {"type": "integer", "minimum": 0},
        "approvedCorrections": {"type": "integer", "minimum": 0},
        "localLexicon": {"type": "integer", "minimum": 0},
        "transliterated": {"type": "integer", "minimum": 0},
        "externallyRefined": {"type": "integer", "minimum": 0}
      }
    },
    "lowConfidenceWords": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "raw", "display", "confidence"],
        "properties": {
          "id": {"type": "string", "pattern": "^word_[0-9]{6}$"},
          "raw": {"type": "string", "minLength": 1},
          "display": {"type": "string", "minLength": 1},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1}
        }
      }
    },
    "warnings": {"type": "array", "items": {"type": "string", "minLength": 1}}
  }
}
